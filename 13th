// SIP CALCULATOR
function fmt(n){return ‘₹’+Math.round(n).toLocaleString(‘en-IN’);}
function calcSIP(){
const amt=+document.getElementById(‘sipAmt’).value;
const retPct=+document.getElementById(‘sipRet’).value;
const ret=retPct/100/12;
const yrs=+document.getElementById(‘sipYrs’).value;
const n=yrs*12;
document.getElementById(‘sipAmtLabel’).textContent=fmt(amt);
document.getElementById(‘sipRetLabel’).textContent=retPct+’%’;
document.getElementById(‘sipYrsLabel’).textContent=yrs+(yrs===1?’ Year’:’ Years’);
const invested=amt*n;
const total=amt*((Math.pow(1+ret,n)-1)/ret)*(1+ret);
const returns=total-invested;
document.getElementById(‘invested’).textContent=fmt(invested);
document.getElementById(‘returns’).textContent=fmt(returns);
document.getElementById(‘total’).textContent=fmt(total);
// Donut
const C=2*Math.PI*70;
const rPct=returns/total;
const iPct=1-rPct;
const iEl=document.getElementById(‘donutI’);
const rEl=document.getElementById(‘donutR’);
iEl.style.strokeDasharray=C;
iEl.style.strokeDashoffset=C-(iPct*C);
rEl.style.strokeDasharray=C;
rEl.style.strokeDashoffset=C-(rPct*C);
rEl.
