<style>


/* ── FONT NORMALIZATION: Same font everywhere ── */
:root {
    color-scheme: dark;
    --font: 'Inter','SF Pro Display',-apple-system,BlinkMacSystemFont,
            'Segoe UI','Helvetica Neue',Arial,sans-serif;
    --font-mono: 'SF Mono','Fira Code','Cascadia Code',Consolas,monospace;
}

/* Force every single element to use the same font */
html, body, h1, h2, h3, h4, h5, h6,
p, span, div, a, button, input, textarea, select,
label, li, td, th, caption, figcaption, blockquote,
.hero-tag, .eyebrow, .section-title, .hero-title,
.stat-num, .stat-lbl, .hs-item .num, .hs-item .lbl,
.vs-num, .vs-lbl, .aic-stat-num, .aic-stat-lbl,
.hcard-val, .cr-val, .dc-pct, .cta-title,
.amfi-badge, .trust-chip, .founder-badge,
.news-tag, .testi-tag, .aic-chip, .onb-chip,
.aic-reg, .aic-location, .aic-brand, .aic-tagline,
.service-title, .svc-title, .svc-desc,
.link-title, .tool-title, .tool-desc,
.nav-logo, .logo-text, nav a,
.footer-col h5, .footer-col ul li a,
.contact-detail .ci-lbl, .contact-detail .ci-val,
.cf-title, .cf-sub, .calc-lbl, .calc-note,
.testi-name, .testi-role, .testi-text,
.founder-name, .founder-role, .founder-exp {
    font-family: var(--font) !important;
}

/* Numbers specifically - tabular rendering */
.stat-num, .hs-item .num, .vs-num, .aic-stat-num,
.hcard-val, .cr-val, .dc-pct, .hero-title,
.section-title, .cta-title, .aic-since span,
#invested, #returns, #total, #sipAmtLabel,
#sipRetLabel, #sipYrsLabel {
    font-family: var(--font) !important;
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum" 1;
    -webkit-font-feature-settings: "tnum" 1;
}

/* ═══ CROSS-PLATFORM RESET ═══ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { -webkit-text-size-adjust: 100%; text-size-adjust: 100%; }
img { max-width: 100%; display: block; }
a { color: inherit; }
button { cursor: pointer; font-family: inherit; }
input, textarea, select { font-family: inherit; }
/* Emoji rendering fix for all platforms */
.emoji, [class*="icon"], [class*="badge"], [class*="chip"],
[class*="btn"], [class*="tag"], [class*="stat"] {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Segoe UI Emoji",
    "Segoe UI Symbol", "Apple Color Emoji", "Noto Color Emoji", sans-serif;
}

:root{--bg:#0B0E11;--card:#1E2329;--card2:#161A1F;--accent:#FCD535;--accent2:#F0B90B;--muted:#848E9C;--border:#2B3139;--green:#0ECB81;--red:#F6465D;--blue:#1E88E5;}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Inter','SF Pro Display',-apple-system,BlinkMacSystemFont,'Segoe UI','Helvetica Neue',Arial,sans-serif;background:var(--bg);color:#fff;overflow-x:hidden;}
::-webkit-scrollbar{width:6px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}* {scrollbar-width:thin;scrollbar-color:var(--border) var(--bg);}

/* TICKER */
.ticker-bar{background:#0d1117;border-bottom:1px solid var(--border);overflow:hidden;height:38px;display:flex;align-items:center;}
.ticker-label{background:var(--accent);color:#000;font-size:0.68rem;font-weight:800;padding:0 14px;height:38px;display:flex;align-items:center;white-space:nowrap;letter-spacing:0.3px;flex-shrink:0;text-transform:uppercase;gap:6px;}
.ticker-scroll{display:flex;gap:0;animation:ticker 55s linear infinite;white-space:nowrap;font-size:0.75rem;padding:0 1.5rem;}
@keyframes ticker{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
.ticker-item{display:inline-flex;align-items:center;gap:0.4rem;padding:0 1.25rem;}
.ticker-sep{color:var(--border);padding:0 0.25rem;}
.ticker-name{color:var(--muted);font-weight:500;}
.ticker-up{color:var(--green);font-weight:600;}
.ticker-down{color:var(--red);font-weight:600;}

/* NAVBAR */
header{background:rgba(11,14,17,0.97);-webkit-backdrop-filter:blur(20px);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:1000;}
.nav-inner{max-width:1280px;margin:0 auto;padding:0 2rem;height:70px;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.logo-icon{width:40px;height:40px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:800;color:#000;box-shadow:0 0 20px rgba(252,213,53,0.3);}
.logo-text{font-size:1.1rem;font-weight:700;color:#fff;letter-spacing:-0.3px;}
.logo-text span{color:var(--accent);}
nav{display:flex;align-items:center;gap:1.75rem;}
nav>a{color:var(--muted);text-decoration:none;font-size:0.82rem;font-weight:500;transition:color 0.2s;display:flex;align-items:center;gap:5px;}
nav>a:hover{color:#fff;}
.nav-divider{width:1px;height:28px;background:var(--border);}
.nav-contact-info{display:flex;gap:1.25rem;font-size:0.72rem;}
.nc-item{display:flex;align-items:center;gap:0.4rem;}
.nc-item i{color:var(--accent);font-size:0.75rem;}
.nc-item a{color:#ccc;text-decoration:none;transition:color 0.2s;}
.nc-item a:hover{color:var(--accent);}
.btn-primary{background:var(--accent);color:#000;border:none;padding:0.5rem 1.25rem;border-radius:7px;font-size:0.83rem;font-weight:700;cursor:pointer;transition:all 0.2s;text-decoration:none;display:inline-flex;align-items:center;gap:6px;}
.btn-primary:hover{background:var(--accent2);box-shadow:0 0 24px rgba(252,213,53,0.4);transform:translateY(-1px);}
.btn-outline{background:transparent;color:#fff;border:1px solid var(--border);padding:0.5rem 1.25rem;border-radius:7px;font-size:0.83rem;font-weight:500;cursor:pointer;transition:all 0.2s;text-decoration:none;display:inline-flex;align-items:center;gap:6px;}
.btn-outline:hover{border-color:var(--accent);color:var(--accent);}

/* HERO */
.hero-section{position:relative;overflow:hidden;min-height:90vh;display:flex;align-items:center;background:linear-gradient(135deg,#0B0E11 0%,#0d1a26 40%,#0a1f1a 70%,#0B0E11 100%);}

.hero-overlay{position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(252,213,53,0.06) 0%,transparent 60%);z-index:1;}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(43,49,57,0.5) 1px,transparent 1px),linear-gradient(90deg,rgba(43,49,57,0.5) 1px,transparent 1px);background-size:64px 64px;opacity:0.4;z-index:1;}
.hero-glow{position:absolute;top:15%;left:25%;width:700px;height:700px;background:radial-gradient(circle,rgba(252,213,53,0.07) 0%,transparent 70%);z-index:1;pointer-events:none;}
.hero-content{position:relative;z-index:2;max-width:1280px;margin:0 auto;padding:80px 2rem;display:grid;grid-template-columns:1.15fr 0.85fr;gap:4rem;align-items:center;width:100%;}
.hero-tag{display:inline-flex;align-items:center;gap:0.5rem;background:rgba(252,213,53,0.1);border:1px solid rgba(252,213,53,0.3);color:var(--accent);font-size:0.72rem;font-weight:700;padding:0.4rem 1rem;border-radius:100px;margin-bottom:1.5rem;letter-spacing:0;text-transform:none;}
.hero-dot{width:7px;height:7px;background:var(--accent);border-radius:50%;animation:pulse 1.8s ease-in-out infinite;}
@keyframes pulse{0%,100%{-webkit-transform:scale(1);transform:scale(1);opacity:1;}50%{-webkit-transform:scale(1.4);transform:scale(1.4);opacity:0.6;}} @-webkit-keyframes pulse{0%,100%{-webkit-transform:scale(1);opacity:1;}50%{-webkit-transform:scale(1.4);opacity:0.6;}}
.hero-title{font-size:clamp(2.4rem,4vw,3.8rem);font-weight:800;line-height:1.1;letter-spacing:-1.5px;margin-bottom:1.25rem;}
.hero-title .accent{color:var(--accent);display:block;}
.hero-desc{color:#9CA3AF;font-size:0.97rem;line-height:1.78;margin-bottom:2rem;max-width:490px;}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:3rem;}
.hero-stats{display:flex;gap:2.5rem;padding-top:2rem;border-top:1px solid var(--border);}
.hs-item .num{font-size:1.75rem;font-weight:800;color:var(--accent);letter-spacing:-0.5px;font-variant-numeric:tabular-nums;}
.hs-item .lbl{font-size:0.68rem;color:var(--muted);margin-top:2px;text-transform:uppercase;letter-spacing:0.2px;}

/* HERO RIGHT */
.hero-right{display:flex;flex-direction:column;gap:1rem;}
.hcard{background:rgba(22,26,31,0.92);-webkit-backdrop-filter:blur(20px);backdrop-filter:blur(20px);border:1px solid var(--border);border-radius:20px;padding:1.5rem;position:relative;overflow:hidden;}
.hcard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--green));}
.hcard-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;}
.hcard-title{font-size:0.75rem;color:var(--muted);font-weight:500;display:flex;align-items:center;gap:5px;}
.hcard-badge{background:rgba(14,203,129,0.15);color:var(--green);font-size:0.68rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:100px;display:flex;align-items:center;gap:4px;}
.mini-bars{display:flex;align-items:flex-end;gap:5px;height:64px;}
.mbar{border-radius:4px 4px 0 0;opacity:0.85;transition:opacity 0.2s;min-width:16px;}
.mbar:hover{opacity:1;}
.hcard-val{font-size:1.85rem;font-weight:800;letter-spacing:0;margin-top:0.6rem;font-variant-numeric:tabular-nums;}
.hcard-sub{font-size:0.72rem;color:var(--muted);margin-top:3px;}
.hero-mini-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.hmc{background:rgba(22,26,31,0.92);-webkit-backdrop-filter:blur(20px);backdrop-filter:blur(20px);border:1px solid var(--border);border-radius:16px;padding:1.1rem;}
.hmc-icon{font-size:1.4rem;margin-bottom:6px;}
.hmc-lbl{font-size:0.68rem;color:var(--muted);margin-bottom:3px;}
.hmc-val{font-size:1.05rem;font-weight:700;}
.hmc-val.g{color:var(--green);}
.hmc-val.y{color:var(--accent);}
.hmc-trend{font-size:0.68rem;margin-top:3px;color:var(--muted);}

/* STATS BAR */
.stats-bar{background:linear-gradient(180deg,#0d1117,#161A1F);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.stats-grid{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);}
.stat-item{padding:2rem 1.5rem;text-align:center;border-right:1px solid var(--border);position:relative;overflow:hidden;transition:background 0.3s;}
.stat-item:last-child{border-right:none;}
.stat-item:hover{background:rgba(252,213,53,0.04);}
.stat-item::after{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:0;height:2px;background:var(--accent);transition:width 0.4s;}
.stat-item:hover::after{width:70%;}
.stat-icon{font-size:1.6rem;margin-bottom:0.5rem;display:block;}
.stat-num{font-size:2.3rem;font-weight:800;color:var(--accent);letter-spacing:-0.5px;line-height:1;font-variant-numeric:tabular-nums;}
.stat-lbl{font-size:0.7rem;color:var(--muted);margin-top:6px;text-transform:uppercase;letter-spacing:0.3px;font-weight:500;}

/* SECTIONS */
section{padding:90px 2rem;}
.section-inner{max-width:1280px;margin:0 auto;}
.section-header{margin-bottom:3.5rem;}
.eyebrow{display:inline-flex;align-items:center;gap:0.5rem;background:rgba(252,213,53,0.08);border:1px solid rgba(252,213,53,0.18);color:var(--accent);font-size:0.68rem;font-weight:700;padding:0.3rem 0.85rem;border-radius:100px;margin-bottom:0.9rem;letter-spacing:0;text-transform:none;}
.section-title{font-size:clamp(1.8rem,3vw,2.5rem);font-weight:800;letter-spacing:-0.8px;line-height:1.2;}
.section-sub{color:var(--muted);margin-top:0.6rem;font-size:0.88rem;line-height:1.65;max-width:580px;}
.section-line{width:50px;height:3px;background:var(--accent);border-radius:2px;margin-top:1rem;}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;}
.about-media{position:relative;}


.about-float{position:relative;display:inline-block;margin-top:1rem;background:var(--accent);color:#000;padding:1rem 1.2rem;border-radius:16px;font-weight:800;font-size:0.88rem;box-shadow:0 12px 30px rgba(252,213,53,0.35);z-index:2;line-height:1.3;}
.about-float .af-small{font-size:0.62rem;font-weight:600;color:rgba(0,0,0,0.55);display:block;margin-top:2px;}
.trust-row{display:flex;gap:0.75rem;margin-top:2.5rem;flex-wrap:wrap;}
.trust-chip{display:flex;align-items:center;gap:5px;background:var(--card);border:1px solid var(--border);border-radius:100px;padding:0.35rem 0.85rem;font-size:0.72rem;font-weight:500;color:#ccc;}
.trust-chip i{color:var(--accent);font-size:0.65rem;}
.about-content p{color:#9CA3AF;line-height:1.85;font-size:0.92rem;margin-bottom:1.2rem;}
.highlight-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.9rem;margin:1.5rem 0;}
.hi{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1rem;display:flex;align-items:center;gap:0.7rem;transition:border-color 0.2s;}
.hi:hover{border-color:rgba(252,213,53,0.3);}
.hi-icon{width:36px;height:36px;background:rgba(252,213,53,0.1);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
.hi-t{font-size:0.8rem;font-weight:600;}
.hi-s{font-size:0.7rem;color:var(--muted);}
.about-reg{background:var(--card2);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:12px;padding:1rem 1.25rem;margin-top:1.5rem;font-size:0.75rem;color:var(--muted);line-height:1.7;}
.about-reg strong{color:#fff;display:block;margin-bottom:0.25rem;}
.about-reg span{color:var(--accent);font-weight:600;}
.amfi-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(14,203,129,0.1);border:1px solid rgba(14,203,129,0.3);color:var(--green);font-size:0.7rem;font-weight:700;padding:0.35rem 0.85rem;border-radius:100px;margin-top:1rem;letter-spacing:0;}

/* SERVICES */
.services-section{background:var(--card2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;}
.svc-card{background:var(--card);border:1px solid var(--border);border-radius:20px;overflow:hidden;transition:all 0.35s;cursor:pointer;}
.svc-card:hover{border-color:rgba(252,213,53,0.45);transform:translateY(-8px);box-shadow:0 30px 60px rgba(0,0,0,0.5);}
.svc-img{position:relative;height:165px;overflow:hidden;display:flex;align-items:center;justify-content:center;}
.svc-img img{display:none;}
.svc-img-fade{display:none;}
.svc-badge{font-size:3rem;line-height:1;z-index:1;}
.svc-img.c1{background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);}
.svc-img.c2{background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);}
.svc-img.c3{background:linear-gradient(135deg,#0d1b2a,#1b263b,#415a77);}
.svc-img.c4{background:linear-gradient(135deg,#1b1b2f,#2e2e4d,#393e6f);}
.svc-img.c5{background:linear-gradient(135deg,#0a2342,#1a3a5c,#126872);}
.svc-img.c6{background:linear-gradient(135deg,#1c0a2e,#2d1b4e,#4a2080);}
.svc-img::after{content:'';position:absolute;bottom:0;left:0;right:0;height:60px;background:linear-gradient(to top,var(--card),transparent);}
.svc-body{padding:1.4rem;}
.svc-title{font-size:0.97rem;font-weight:700;margin-bottom:0.45rem;}
.svc-desc{color:var(--muted);font-size:0.79rem;line-height:1.65;margin-bottom:0.9rem;}
.svc-link{display:inline-flex;align-items:center;gap:5px;color:var(--accent);font-size:0.78rem;font-weight:600;text-decoration:none;transition:gap 0.2s;}
.svc-link:hover{gap:10px;}

/* TOOLS */
.tools-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;}
.tool-card{background:var(--card);border:1px solid var(--border);border-radius:20px;overflow:hidden;text-decoration:none;transition:all 0.35s;display:flex;flex-direction:column;}
.tool-card:hover{transform:translateY(-8px);border-color:rgba(252,213,53,0.4);box-shadow:0 30px 60px rgba(0,0,0,0.5);}
.tool-img{position:relative;height:130px;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:2.5rem;}
.tool-img img{display:none;}
.tool-img-fade{display:none;}
.tool-img.t1{background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);}
.tool-img.t2{background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);}
.tool-img.t3{background:linear-gradient(135deg,#0d1b2a,#1b263b,#415a77);}
.tool-img.t4{background:linear-gradient(135deg,#1b1b2f,#2e2e4d,#393e6f);}
.tool-img.t5{background:linear-gradient(135deg,#0a2342,#1a3a5c,#126872);}
.tool-img.t6{background:linear-gradient(135deg,#1c0a2e,#2d1b4e,#4a2080);}
.tool-img::after{content:'';position:absolute;bottom:0;left:0;right:0;height:50px;background:linear-gradient(to top,var(--card),transparent);}
.tool-body{padding:1.35rem;flex:1;display:flex;flex-direction:column;gap:0.4rem;}
.tool-icon-row{display:flex;align-items:center;gap:0.7rem;margin-bottom:0.2rem;}
.tool-box{width:42px;height:42px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;}
.tool-box.y{background:rgba(252,213,53,0.1);border:1px solid rgba(252,213,53,0.18);}
.tool-box.g{background:rgba(14,203,129,0.1);border:1px solid rgba(14,203,129,0.18);}
.tool-box.b{background:rgba(96,165,250,0.1);border:1px solid rgba(96,165,250,0.18);}
.tool-title{font-size:0.92rem;font-weight:700;}
.tool-title.y{color:var(--accent);}
.tool-title.g{color:var(--green);}
.tool-title.b{color:#60A5FA;}
.tool-desc{color:var(--muted);font-size:0.78rem;line-height:1.55;flex:1;}
.tool-arrow{display:inline-flex;align-items:center;gap:5px;color:var(--muted);font-size:0.72rem;margin-top:0.4rem;transition:all 0.2s;}
.tool-card:hover .tool-arrow{color:var(--accent);gap:10px;}

/* SIP CALC */
.calc-section{background:var(--card2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.calc-grid{display:grid;grid-template-columns:1.15fr 0.85fr;gap:4rem;align-items:start;}
.calc-card{background:var(--card);border:1px solid var(--border);border-radius:22px;padding:2.2rem;position:relative;overflow:hidden;}
.calc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2.5px;background:linear-gradient(90deg,var(--accent),var(--green));}
.calc-field{margin-bottom:1.7rem;}
.calc-lbl{font-size:0.8rem;color:var(--muted);font-weight:500;margin-bottom:0.6rem;display:flex;justify-content:space-between;align-items:center;}
.calc-lbl .cv{color:var(--accent);font-weight:700;font-size:0.85rem;}
input[type=range]{-webkit-appearance:none;width:100%;height:5px;background:var(--border);border-radius:3px;outline:none;cursor:pointer;}

/* Range input cross-browser */
input[type=range]::-moz-range-thumb{width:20px;height:20px;border-radius:50%;background:var(--accent);cursor:pointer;border:3px solid var(--bg);}
input[type=range]::-ms-thumb{width:20px;height:20px;border-radius:50%;background:var(--accent);cursor:pointer;}
input[type=range]::-moz-range-track{height:5px;background:var(--border);border-radius:3px;}
input[type=range]::-ms-track{height:5px;background:var(--border);border-radius:3px;border-color:transparent;color:transparent;}

input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--accent);cursor:pointer;border:3px solid var(--bg);box-shadow:0 0 10px rgba(252,213,53,0.4);}
.calc-result{background:linear-gradient(135deg,rgba(252,213,53,0.04),rgba(14,203,129,0.02));border:1px solid rgba(252,213,53,0.18);border-radius:18px;padding:1.75rem;margin-top:1.75rem;}
.cr-row{display:flex;justify-content:space-between;align-items:center;padding:0.8rem 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:0.88rem;}
.cr-row:last-child{border-bottom:none;}
.cr-lbl{color:var(--muted);display:flex;align-items:center;gap:6px;}
.cr-lbl i{color:var(--accent);font-size:0.8rem;}
.cr-val{font-weight:600;}
.cr-total{background:rgba(252,213,53,0.06);border-radius:12px;padding:0.9rem 1rem;margin-top:0.5rem;display:flex;justify-content:space-between;align-items:center;}
.cr-total .cr-lbl{color:#fff;font-weight:700;font-size:0.95rem;}
.cr-total .cr-val{color:var(--accent);font-size:1.35rem;font-weight:800;letter-spacing:0;font-variant-numeric:tabular-nums;}
.calc-note{font-size:0.69rem;color:var(--muted);margin-top:1.2rem;line-height:1.6;padding-top:1rem;border-top:1px solid var(--border);}
.donut-area{display:flex;flex-direction:column;align-items:center;margin-bottom:1.75rem;}
.donut-chart{position:relative;width:190px;height:190px;margin-bottom:1rem;}
.donut-chart svg{transform:rotate(-90deg);}
.donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.dc-pct{font-size:1.5rem;font-weight:800;color:var(--accent);}
.dc-lbl{font-size:0.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;}
.donut-legend{display:flex;gap:1.5rem;}
.dl{display:flex;align-items:center;gap:6px;font-size:0.75rem;color:var(--muted);}
.dl-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.sip-reasons{display:flex;flex-direction:column;gap:0.8rem;}
.sir{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:1rem 1.15rem;display:flex;gap:0.9rem;align-items:flex-start;transition:border-color 0.2s;}
.sir:hover{border-color:rgba(252,213,53,0.25);}
.sir-icon{width:38px;height:38px;border-radius:9px;background:rgba(252,213,53,0.1);display:flex;align-items:center;justify-content:center;font-size:0.95rem;flex-shrink:0;}
.sir-t{font-size:0.82rem;font-weight:600;margin-bottom:2px;}
.sir-d{font-size:0.75rem;color:var(--muted);line-height:1.5;}

/* NEWS */
.news-grid{display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;}
.news-feat{background:var(--card);border:1px solid var(--border);border-radius:20px;overflow:hidden;transition:all 0.3s;cursor:pointer;}
.news-feat:hover{border-color:rgba(252,213,53,0.3);box-shadow:0 30px 60px rgba(0,0,0,0.4);}
.news-feat-img{position:relative;height:270px;overflow:hidden;background:#0f2027;}
.news-feat-img img{display:none;}
.news-feat:hover .news-feat-img img{display:none;}
.news-feat-img .nf-fade{position:absolute;inset:0;background:linear-gradient(to top,rgba(30,35,41,1) 0%,transparent 50%);}
.news-body{padding:1.5rem;}
.news-tag{display:inline-flex;align-items:center;gap:4px;font-size:0.66rem;color:var(--accent);font-weight:700;text-transform:uppercase;letter-spacing:0.3px;margin-bottom:0.45rem;}
.news-ttl{font-size:1rem;font-weight:700;line-height:1.4;margin-bottom:0.45rem;}
.news-ttl.lg{font-size:1.15rem;}
.news-desc{color:var(--muted);font-size:0.8rem;line-height:1.6;}
.news-meta{display:flex;align-items:center;gap:1rem;margin-top:0.9rem;font-size:0.7rem;color:var(--muted);}
.news-sidebar{display:flex;flex-direction:column;gap:1.2rem;}
.news-sm{background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;transition:all 0.3s;cursor:pointer;display:grid;grid-template-columns:95px 1fr;}
.news-sm:hover{border-color:rgba(252,213,53,0.25);}
.news-sm img{width:100%;height:100%;object-fit:cover;filter:brightness(0.72);}
.news-sm-body{padding:0.9rem;}

/* VISION */
.vision-section{background:var(--card2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.vision-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:4rem;align-items:center;}
.founder-card{background:var(--card);border:1px solid var(--border);border-radius:24px;padding:2.5rem;text-align:center;position:relative;overflow:hidden;}
.founder-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2.5px;background:linear-gradient(90deg,var(--accent),var(--green),var(--accent));}
.founder-glow{position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:220px;height:220px;background:radial-gradient(circle,rgba(252,213,53,0.07),transparent 70%);pointer-events:none;}
.founder-av-wrap{position:relative;display:inline-block;margin-bottom:1.2rem;}
.founder-av{width:128px;height:128px;border-radius:50%;object-fit:cover;border:3px solid var(--accent);box-shadow:0 0 0 6px rgba(252,213,53,0.1),0 0 28px rgba(252,213,53,0.2);}
.founder-check{position:absolute;bottom:4px;right:4px;background:var(--accent);border-radius:50%;width:26px;height:26px;display:flex;align-items:center;justify-content:center;border:2px solid var(--card);}
.founder-check i{font-size:0.7rem;color:#000;}
.founder-name{font-size:1.2rem;font-weight:800;margin-bottom:0.3rem;}
.founder-role{color:var(--accent);font-size:0.83rem;font-weight:600;margin-bottom:0.25rem;}
.founder-exp{color:var(--muted);font-size:0.76rem;}
.founder-badges{display:flex;gap:0.5rem;justify-content:center;margin-top:1.2rem;flex-wrap:wrap;}
.fb{background:rgba(252,213,53,0.08);border:1px solid rgba(252,213,53,0.16);color:var(--accent);font-size:0.66rem;padding:0.28rem 0.7rem;border-radius:100px;font-weight:600;}
.founder-socials{display:flex;gap:0.7rem;justify-content:center;margin-top:1.4rem;}
.fsoc{width:36px;height:36px;border-radius:9px;background:var(--card2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:0.85rem;text-decoration:none;transition:all 0.2s;}
.fsoc:hover{border-color:var(--accent);color:var(--accent);}
.vision-quote{font-size:1.02rem;line-height:1.88;color:#C0C7D0;border-left:3px solid var(--accent);padding-left:1.5rem;font-style:italic;margin:1.5rem 0;position:relative;}
.vision-quote::before{content:'\201C';position:absolute;top:-18px;left:8px;font-size:4rem;color:rgba(252,213,53,0.12);font-family:Georgia,serif;line-height:1;}
.vision-author{display:flex;align-items:center;gap:0.75rem;color:var(--accent);font-weight:700;font-size:0.88rem;}
.vision-author::before{content:'';width:38px;height:2px;background:var(--accent);}
.vision-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1.1rem;margin-top:2.5rem;}
.vs{background:var(--card);border:1px solid var(--border);border-radius:15px;padding:1.2rem;text-align:center;transition:border-color 0.2s;}
.vs:hover{border-color:rgba(252,213,53,0.3);}
.vs-num{font-size:1.7rem;font-weight:800;letter-spacing:0;font-variant-numeric:tabular-nums;}
.vs-lbl{font-size:0.68rem;color:var(--muted);margin-top:4px;text-transform:uppercase;letter-spacing:0.5px;}

/* TESTIMONIALS */
.testi-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;}
.testi-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:1.9rem;transition:all 0.3s;position:relative;overflow:hidden;}
.testi-card::before{content:'\201C';position:absolute;top:8px;right:18px;font-size:5rem;color:rgba(252,213,53,0.07);font-family:Georgia,serif;line-height:1;}
.testi-card:hover{border-color:rgba(252,213,53,0.3);transform:translateY(-5px);box-shadow:0 20px 45px rgba(0,0,0,0.4);}
.testi-header{display:flex;align-items:center;gap:0.9rem;margin-bottom:1.1rem;}
.testi-av{width:50px;height:50px;border-radius:50%;object-fit:cover;border:2px solid var(--border);}
.testi-name{font-weight:700;font-size:0.93rem;}
.testi-role{font-size:0.7rem;color:var(--muted);margin-top:2px;display:flex;align-items:center;gap:4px;}
.testi-stars{color:var(--accent);font-size:0.8rem;margin-top:3px;letter-spacing:1.5px;}
.testi-text{color:#9CA3AF;font-size:0.83rem;line-height:1.75;}
.testi-tag{display:inline-flex;align-items:center;gap:4px;background:rgba(252,213,53,0.07);color:var(--accent);font-size:0.66rem;font-weight:600;padding:0.22rem 0.65rem;border-radius:100px;margin-top:0.9rem;}

/* CONTACT */
.contact-section{background:var(--card2);border-top:1px solid var(--border);}
.contact-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:4rem;align-items:start;}
.ci{display:flex;gap:1rem;align-items:flex-start;margin-bottom:1.6rem;}
.ci-icon{width:46px;height:46px;border-radius:13px;background:rgba(252,213,53,0.1);border:1px solid rgba(252,213,53,0.25);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;}
.ci-lbl{color:var(--muted);font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:4px;}
.ci-val{font-size:0.88rem;font-weight:500;line-height:1.55;}
.ci-val a{color:#fff;text-decoration:none;transition:color 0.2s;}
.ci-val a:hover{color:var(--accent);}

.contact-form{background:var(--card);border:1px solid var(--border);border-radius:22px;padding:2.2rem;position:relative;overflow:hidden;}
.contact-form::before{content:'';position:absolute;top:0;left:0;right:0;height:2.5px;background:linear-gradient(90deg,var(--accent),var(--green));}
.cf-title{font-size:1.1rem;font-weight:700;margin-bottom:0.35rem;}
.cf-sub{font-size:0.78rem;color:var(--muted);margin-bottom:1.7rem;display:flex;align-items:center;gap:5px;}
.cf-sub i{color:var(--accent);}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.fg{margin-bottom:1rem;}
.fg label{display:flex;align-items:center;gap:4px;font-size:0.76rem;color:var(--muted);margin-bottom:0.42rem;font-weight:500;}
.fg label i{font-size:0.68rem;color:var(--accent);}
.fg input,.fg textarea,.fg select{width:100%;background:var(--bg);border:1px solid var(--border);color:#fff;padding:0.78rem 1rem;border-radius:9px;font-family:'Inter','SF Pro Display',-apple-system,BlinkMacSystemFont,'Segoe UI','Helvetica Neue',Arial,sans-serif;font-size:0.83rem;outline:none;transition:border-color 0.2s,box-shadow 0.2s;}
.fg input:focus,.fg textarea:focus,.fg select:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(252,213,53,0.08);}
.fg input::placeholder,.fg textarea::placeholder{color:rgba(132,142,156,0.45);}
.fg textarea{resize:vertical;min-height:108px;}
.fg select option{background:var(--card);}
.app-btns{display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1rem;}
.app-btn{display:flex;align-items:center;gap:0.55rem;background:var(--card);border:1px solid var(--border);color:#fff;padding:0.55rem 1rem;border-radius:10px;font-size:0.75rem;text-decoration:none;transition:all 0.2s;}
.app-btn:hover{border-color:var(--accent);color:var(--accent);}
/* ABOUT INFO CARD */
.about-info-card{background:var(--card);border:1px solid var(--border);border-radius:24px;overflow:hidden;box-shadow:0 40px 80px rgba(0,0,0,0.5);position:relative;}
.about-info-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--green),var(--accent));}
.aic-header{display:flex;align-items:center;gap:1rem;padding:1.5rem 1.5rem 1rem;border-bottom:1px solid var(--border);}
.aic-logo-box{width:48px;height:48px;background:var(--accent);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;color:#000;flex-shrink:0;}
.aic-brand{font-size:1.1rem;font-weight:800;color:#fff;}
.aic-tagline{font-size:0.72rem;color:var(--muted);margin-top:2px;}
.aic-since{margin-left:auto;text-align:center;font-size:0.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;line-height:1.4;}
.aic-since span{display:block;font-size:1.4rem;font-weight:800;color:var(--accent);letter-spacing:0;}
.aic-mission{font-size:0.82rem;color:#9CA3AF;line-height:1.75;font-style:italic;padding:1rem 1.5rem;border-bottom:1px solid var(--border);border-left:3px solid var(--accent);margin:0 1.5rem 0;background:rgba(252,213,53,0.03);border-radius:0 8px 8px 0;}
.aic-stats{display:flex;align-items:center;justify-content:space-around;padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);gap:0.5rem;}
.aic-stat{text-align:center;}
.aic-stat-num{font-size:1.35rem;font-weight:800;color:var(--accent);letter-spacing:0;font-variant-numeric:tabular-nums;}
.aic-stat-lbl{font-size:0.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-top:2px;}
.aic-stat-div{width:1px;height:32px;background:var(--border);}
.aic-services{padding:1.1rem 1.5rem;border-bottom:1px solid var(--border);}
.aic-svc-title{font-size:0.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.8px;font-weight:700;margin-bottom:0.65rem;}
.aic-svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0.5rem;}
.aic-svc-item{background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:0.5rem 0.6rem;font-size:0.73rem;color:#ccc;display:flex;align-items:center;gap:0.4rem;transition:border-color 0.2s;}
.aic-svc-item:hover{border-color:rgba(252,213,53,0.3);color:#fff;}
.aic-clients{padding:1.1rem 1.5rem;border-bottom:1px solid var(--border);}
.aic-client-chips{display:flex;gap:0.6rem;flex-wrap:wrap;margin-top:0.5rem;}
.aic-chip{background:rgba(252,213,53,0.08);border:1px solid rgba(252,213,53,0.2);color:var(--accent);font-size:0.72rem;font-weight:600;padding:0.3rem 0.8rem;border-radius:100px;}
.aic-footer{display:flex;justify-content:space-between;align-items:center;padding:0.9rem 1.5rem;font-size:0.7rem;}
.aic-reg{background:rgba(14,203,129,0.1);border:1px solid rgba(14,203,129,0.25);color:var(--green);padding:0.25rem 0.7rem;border-radius:100px;font-weight:600;letter-spacing:0;}
.aic-location{color:var(--muted);}

.office-card{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:1.4rem;margin-top:1.5rem;overflow:hidden;position:relative;}
.office-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--green));}
.office-card-header{display:flex;align-items:center;gap:0.75rem;margin-bottom:1.1rem;}
.office-map-pin{width:42px;height:42px;background:rgba(252,213,53,0.12);border:1px solid rgba(252,213,53,0.25);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;}
.office-card-title{font-size:0.92rem;font-weight:700;color:#fff;}
.office-card-sub{font-size:0.72rem;color:var(--muted);margin-top:2px;}
.office-directions-btn{margin-left:auto;background:rgba(252,213,53,0.1);border:1px solid rgba(252,213,53,0.3);color:var(--accent);font-size:0.72rem;font-weight:600;padding:0.35rem 0.85rem;border-radius:100px;text-decoration:none;white-space:nowrap;transition:all 0.2s;}
.office-directions-btn:hover{background:var(--accent);color:#000;}
.office-details-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1.1rem;}
.office-detail-item{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:0.65rem 0.85rem;}
.odi-label{font-size:0.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.6px;margin-bottom:3px;font-weight:600;}
.odi-value{font-size:0.78rem;color:#fff;font-weight:500;}
.onb-title{font-size:0.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.6px;margin-bottom:0.5rem;font-weight:600;}
.onb-chips{display:flex;flex-wrap:wrap;gap:0.5rem;}
.onb-chip{background:var(--bg);border:1px solid var(--border);color:#ccc;font-size:0.7rem;padding:0.28rem 0.7rem;border-radius:100px;}


/* CTA */
.cta-section{position:relative;overflow:hidden;padding:100px 2rem;text-align:center;background:var(--bg);}
.cta-section::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(252,213,53,0.09) 0%,transparent 65%);}
.cta-section::after{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(43,49,57,0.35) 1px,transparent 1px),linear-gradient(90deg,rgba(43,49,57,0.35) 1px,transparent 1px);background-size:72px 72px;}
.cta-inner{position:relative;z-index:2;}
.cta-title{font-size:clamp(2rem,4vw,3.2rem);font-weight:800;letter-spacing:-0.5px;margin-bottom:1rem;}
.cta-sub{color:var(--muted);font-size:0.97rem;margin-bottom:2.5rem;}
.cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;}

/* FOOTER */
footer{background:var(--card2);border-top:1px solid var(--border);}
.footer-inner{max-width:1280px;margin:0 auto;padding:3.5rem 2rem;display:grid;grid-template-columns:2.2fr 1fr 1fr 1.5fr;gap:3rem;}
.footer-brand p{color:var(--muted);font-size:0.79rem;line-height:1.78;margin:1rem 0;max-width:275px;}
.footer-col h5{font-size:0.73rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:1.2rem;color:#fff;}
.footer-col ul{list-style:none;}
.footer-col ul li{margin-bottom:0.55rem;}
.footer-col ul li a{color:var(--muted);text-decoration:none;font-size:0.79rem;transition:color 0.2s;display:flex;align-items:center;gap:5px;}
.footer-col ul li a i{font-size:0.6rem;color:var(--border);transition:color 0.2s;}
.footer-col ul li a:hover{color:var(--accent);}
.footer-col ul li a:hover i{color:var(--accent);}
.footer-contact .fi{display:flex;gap:0.7rem;align-items:flex-start;margin-bottom:0.8rem;font-size:0.78rem;color:var(--muted);}
.footer-contact .fi i{color:var(--accent);font-size:0.82rem;margin-top:2px;flex-shrink:0;}
.footer-social{display:flex;gap:0.6rem;margin-top:1.2rem;}
.fsb{width:33px;height:33px;border-radius:8px;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:0.78rem;text-decoration:none;transition:all 0.2s;}
.fsb:hover{border-color:var(--accent);color:var(--accent);background:rgba(252,213,53,0.07);}
.footer-bottom{border-top:1px solid var(--border);padding:1.2rem 2rem;max-width:1280px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;font-size:0.71rem;color:var(--muted);flex-wrap:wrap;gap:0.5rem;}
.footer-bottom a{color:var(--accent);text-decoration:none;}
.risk-box{background:rgba(246,70,93,0.04);border:1px solid rgba(246,70,93,0.14);border-radius:11px;padding:1.2rem 1.75rem;font-size:0.69rem;color:#6B7280;line-height:1.72;margin:0 2rem;max-width:1280px;margin-left:auto;margin-right:auto;}
.risk-box strong{color:#F6465D;}

@keyframes fadeUp{from{opacity:0;transform:translateY(24px);}to{opacity:1;transform:translateY(0);}}
.fade-up{opacity:0;animation:fadeUp 0.7s ease forwards;}
