  text-decoration: none;
  font-size: 0.85rem;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  transition: gap 0.2s;
}
.service-link:hover { gap: 0.7rem; }

/* ── DISCLAIMER BANNER ── */
.mf-banner {
  background: linear-gradient(135deg, var(--teal), var(--deep));
  padding: 4rem 0;
  text-align: center;
}
.mf-banner h2 {
