.link-card:hover { background: var(--deep); color: var(--white); transform: translateY(-3px); box-shadow: 0 10px 30px rgba(10,22,40,0.2); }
.link-card:hover .link-icon { background: rgba(255,255,255,0.1); }
.link-icon {
  width: 48px;
  height: 48px;
  background: var(--offwhite);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  flex-shrink: 0;
  transition: background 0.3s;
}
.link-card span { font-weight: 600; font-size: 0.9rem; }

