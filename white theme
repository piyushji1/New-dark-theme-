.videos { background: var(--white); }
.videos-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 2.5rem; }
.video-wrap {
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(0,0,0,0.1);
  aspect-ratio: 16/9;
}
.video-wrap iframe { width: 100%; height: 100%; border: none; }

/* ── LINKS GRID ── */
.quick-links { background: var(--offwhite); }
.links-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2.5rem; }
.link-card {
  background: var(--white);
